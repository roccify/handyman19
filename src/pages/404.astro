---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="404 — Page Not Found">
  <div style="min-height:60vh; display:flex; align-items:center; justify-content:center; text-align:center; padding:4rem 1rem;">
    <div>
      <p style="font-size:6rem; font-weight:900; color:#F2A93B; line-height:1;">404</p>
      <h1 style="font-size:2rem; font-weight:700; margin:1rem 0;">Page Not Found</h1>
      <p style="color:#777; margin-bottom:2rem;">The page you're looking for doesn't exist.</p>
      <a href="/" style="background:#F2A93B; color:#000; font-weight:700; padding:0.875rem 2rem; display:inline-block;">
        Back to Home
      </a>
    </div>
  </div>
</MainLayout>

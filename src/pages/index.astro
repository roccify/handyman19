---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import Testimonials from '../components/Testimonials.astro';
import QuoteForm from '../components/QuoteForm.astro';
import Gallery from '../components/Gallery.astro';
import content from '../data/content.json';

const { businessName, services, homepageServiceIds, whyChooseUs, faq, ctaBanner, intro, foundedYear } = content;
const homeServices = services.filter(s => (homepageServiceIds ?? services.map(s => s.id)).includes(s.id));
---

<MainLayout title={content.seo.home.title} description={content.seo.home.description} ogImage={content.seo.home.ogImage}>

  <!-- 1. HERO -->
  <Hero />

  <!-- 2. SERVICES GRID -->
  <section style="position:relative; z-index:10; background:#f4f4f4; padding-bottom:60px;">
    <div style="background:#fff; height:12px;"></div>
    <div style="max-width:1200px; margin:0 auto; padding:20px 20px 0;">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {homeServices.map((svc) => (
          <a href={`/services#${svc.id}`}
            class="group bg-white flex flex-col text-center no-underline overflow-hidden rounded"
            style="box-shadow:0 3px 16px rgba(0,0,0,0.09); text-decoration:none;"
          >
            <div class="overflow-hidden flex-shrink-0" style="height:200px; background:#e5e7eb;">
              <img
                src={svc.image?.url ?? ''}
                alt={svc.image?.alt ?? svc.name}
                class="w-full h-full object-cover block group-hover:scale-105 transition-transform duration-500"
                onerror="this.style.display='none';"
              />
            </div>
            <div class="flex flex-col flex-1 p-6">
              <h3 class="font-extrabold text-gray-900 mb-2" style="font-size:1.1rem;">{svc.name}</h3>
              <p class="text-gray-500 text-sm leading-relaxed flex-1 mb-5">{svc.shortDescription}</p>
              <div>
                <span class="inline-block font-bold text-sm px-6 py-2.5 rounded-full" style="background:#F2A93B; color:#111;">
                  Read More
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. INTRO + WHY CHOOSE US -->
  <section class="py-20" style="background:#f9f9f9;">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p class="uppercase text-xs tracking-widest text-gray-400 font-semibold mb-3">WHY RELIABLEFIX</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-6">Built on Trust Since {foundedYear}</h2>
        <p class="text-base text-gray-500 max-w-2xl mx-auto">{intro.text}</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {whyChooseUs.map((item) => (
          <div class="bg-white p-7 text-center" style="border:1px solid #e5e7eb;">
            <div class="w-12 h-12 mx-auto mb-5 flex items-center justify-center" style="background:#F2A93B;">
              {item.icon === 'shield' && <svg class="w-5 h-5" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>}
              {item.icon === 'clock' && <svg class="w-5 h-5" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>}
              {item.icon === 'dollar' && <svg class="w-5 h-5" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>}
              {item.icon === 'star' && <svg class="w-5 h-5" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>}
              {!['shield','clock','dollar','star'].includes(item.icon) && <svg class="w-5 h-5" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>}
            </div>
            <p class="text-sm font-semibold text-gray-800 leading-snug">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. TESTIMONIALS -->
  <Testimonials />

  <!-- 5. FAQ — two independent accordion columns, Avada style -->
  <section style="padding:80px 24px; background:#fff;">
    <div style="max-width:1140px; margin:0 auto;">
      <div style="text-align:center; margin-bottom:56px;">
        <p style="text-transform:uppercase; font-size:0.7rem; letter-spacing:0.15em; color:#aaa; font-weight:600; margin:0 0 10px;">COMMON QUESTIONS</p>
        <h2 style="font-size:2.5rem; font-weight:700; color:#111; margin:0;">Frequently Asked Questions</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12">
        <div class="faq-col">
          {content.faq.filter((_,i)=>i%2===0).map((item) => (
            <div class="faq-item" style="border-bottom:1px solid #e5e7eb; cursor:pointer;">
              <div style="display:flex; align-items:center; justify-content:space-between; gap:16px; padding:18px 0;">
                <span style="font-weight:700; color:#111; font-size:0.95rem;">{item.question}</span>
                <div class="faq-box" style="width:28px; height:28px; flex-shrink:0; border:1px solid #ddd; display:flex; align-items:center; justify-content:center; transition:border-color 0.2s;">
                  <span class="faq-icon" style="font-size:1rem; font-weight:700; color:#888; line-height:1;">+</span>
                </div>
              </div>
              <p class="faq-answer" style="display:none; padding:0 0 16px; color:#666; font-size:0.92rem; line-height:1.75; margin:0;">{item.answer}</p>
            </div>
          ))}
        </div>
        <div class="faq-col">
          {content.faq.filter((_,i)=>i%2!==0).map((item) => (
            <div class="faq-item" style="border-bottom:1px solid #e5e7eb; cursor:pointer;">
              <div style="display:flex; align-items:center; justify-content:space-between; gap:16px; padding:18px 0;">
                <span style="font-weight:700; color:#111; font-size:0.95rem;">{item.question}</span>
                <div class="faq-box" style="width:28px; height:28px; flex-shrink:0; border:1px solid #ddd; display:flex; align-items:center; justify-content:center; transition:border-color 0.2s;">
                  <span class="faq-icon" style="font-size:1rem; font-weight:700; color:#888; line-height:1;">+</span>
                </div>
              </div>
              <p class="faq-answer" style="display:none; padding:0 0 16px; color:#666; font-size:0.92rem; line-height:1.75; margin:0;">{item.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('.faq-col').forEach(col => {
      col.querySelectorAll('.faq-item').forEach(item => {
        item.addEventListener('click', () => {
          const answer = item.querySelector('.faq-answer');
          const icon = item.querySelector('.faq-icon');
          const box = item.querySelector('.faq-box');
          const isOpen = answer.style.display !== 'none';
          col.querySelectorAll('.faq-item').forEach(el => {
            el.querySelector('.faq-answer').style.display = 'none';
            el.querySelector('.faq-icon').textContent = '+';
            el.querySelector('.faq-icon').style.color = '#888';
            el.querySelector('.faq-box').style.borderColor = '#ddd';
          });
          if (!isOpen) {
            answer.style.display = 'block';
            icon.textContent = '×';
            icon.style.color = '#F2A93B';
            box.style.borderColor = '#F2A93B';
          }
        });
      });
    });
  </script>

  <!-- 6. GALLERY -->
  <Gallery />

  <!-- 7. CTA BANNER -->
  <section class="py-24 relative" style="background-image:url('/images/cta-banner.jpg');background-size:cover;background-position:center;">
    <div class="absolute inset-0" style="background:rgba(0,0,0,0.72);"></div>
    <img src={ctaBanner.image?.url ?? '/images/cta-banner.jpg'} alt={ctaBanner.image?.alt ?? ''} style="display:none;" />
    <div class="relative z-10 max-w-4xl mx-auto px-6 lg:px-10 text-center">
      <h2 class="text-4xl font-bold text-white mb-4">{ctaBanner.headline}</h2>
      <p class="text-gray-300 text-base mb-8">{ctaBanner.subheadline}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={ctaBanner.ctaPrimary.href} style="background:#F2A93B;" class="inline-block text-black font-bold text-sm px-8 py-4 hover:brightness-95 transition-all">
          {ctaBanner.ctaPrimary.label}
        </a>
        <a href={ctaBanner.ctaSecondary.href} class="inline-block text-white font-bold text-sm px-8 py-4 border-2 border-white hover:bg-white hover:text-black transition-all">
          {ctaBanner.ctaSecondary.label}
        </a>
      </div>
    </div>
  </section>

  <!-- 7. QUOTE FORM -->
  <QuoteForm />

</MainLayout>

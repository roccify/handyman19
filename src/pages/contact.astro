---
import MainLayout from '../layouts/MainLayout.astro';
import QuoteForm from '../components/QuoteForm.astro';
import content from '../data/content.json';
const { contact, hours, heroes, serviceArea } = content;
---

<MainLayout title={content.seo.contact.title} description={content.seo.contact.description} ogImage={content.seo.contact.ogImage}>

  <!-- HERO: yellow wave -->
  <div style="background:#F2A93B;" class="pb-0">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 text-center">
      <p class="uppercase text-xs tracking-widest font-semibold text-black/60 mb-3">GET IN TOUCH</p>
      <h1 class="text-5xl font-bold tracking-tight text-black">{heroes.contact.headline}</h1>
      <p class="mt-3 text-black/70 text-base">{heroes.contact.subheadline}</p>
    </div>
    <div style="overflow:hidden; line-height:0;">
      <svg viewBox="0 0 1200 80" preserveAspectRatio="none" style="display:block; width:100%; height:60px;">
        <path d="M0,40 C200,80 400,0 600,40 C800,80 1000,0 1200,40 L1200,80 L0,80 Z" fill="#ffffff"/>
      </svg>
    </div>
  </div>

  <!-- 3 CONTACT CARDS -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <div class="p-8 shadow-md text-center flex flex-col items-center" style="border-top: 3px solid #F2A93B;">
          <div class="w-14 h-14 flex items-center justify-center mb-5" style="background:#F2A93B;">
            <svg class="w-6 h-6" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-2">Phone</h3>
          <a href={contact.phoneClick} class="text-base font-bold hover:underline" style="color:#F2A93B;">{contact.phoneDisplay}</a>
          <p class="text-sm text-gray-400 mt-1">{hours.weekdays}</p>
        </div>

        <div class="p-8 shadow-md text-center flex flex-col items-center" style="border-top: 3px solid #F2A93B;">
          <div class="w-14 h-14 flex items-center justify-center mb-5" style="background:#F2A93B;">
            <svg class="w-6 h-6" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-2">Email</h3>
          <a href={`mailto:${contact.email}`} class="text-base hover:underline break-all" style="color:#F2A93B;">{contact.email}</a>
          <p class="text-sm text-gray-400 mt-1">Response within one business day</p>
        </div>

        <div class="p-8 shadow-md text-center flex flex-col items-center" style="border-top: 3px solid #F2A93B;">
          <div class="w-14 h-14 flex items-center justify-center mb-5" style="background:#F2A93B;">
            <svg class="w-6 h-6" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-2">Hours</h3>
          <p class="text-base text-gray-600">{hours.weekdays}</p>
          <p class="text-base text-gray-600">{hours.saturday}</p>
          <p class="text-base text-gray-600">{hours.sunday}</p>
        </div>

      </div>
    </div>
  </section>

  <!-- QUOTE FORM -->
  <QuoteForm />

  <!-- MAP -->
  <section class="bg-white">
    <div class="w-full" style="height:400px;">
      <iframe
        src={contact.googleMapsEmbed}
        width="100%" height="100%"
        style="border:0;" allowfullscreen="" loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="ReliableFix location map"
      ></iframe>
    </div>
  </section>



</MainLayout>

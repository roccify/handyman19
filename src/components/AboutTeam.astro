---
import content from '../data/content.json';
const team = content.about.team;
---

<section class="py-12 md:py-16 bg-gray-50 border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row-reverse gap-12 lg:gap-16 items-center">

      <div class="lg:w-5/12">
        <div class="overflow-hidden aspect-[4/3]" style={`background: ${team.image.fallback}`}>
          <img
            src={team.image.url}
            alt={team.image.alt}
            class="w-full h-full object-cover"
            loading="lazy"
            onerror="this.style.display='none'"
          />
        </div>
      </div>

      <div class="lg:w-7/12">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-0.5" style="background:#F2A93B;"></div>
          <span class="text-xs font-bold uppercase tracking-widest" style="color:#F2A93B;">Our Team</span>
        </div>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-gray-900 mb-5">
          Technicians You Can Trust
        </h2>
        <p class="text-gray-600 leading-relaxed text-lg">{team.description}</p>
      </div>

    </div>
  </div>
</section>

---
import content from '../data/content.json';
const c = content.contact;
const hours = content.hours;
---

<section class="py-12 md:py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-0.5" style="background:#F2A93B;"></div>
        <span class="text-xs font-bold uppercase tracking-widest" style="color:#F2A93B;">Contact Details</span>
      </div>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-gray-900">Reach Us Directly</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-gray-200">

      <div class="bg-white p-8" style="border-top: 2px solid #F2A93B;">
        <div class="w-12 h-12 flex items-center justify-center mb-5" style="background:#F2A93B;">
          <svg class="w-6 h-6 text-gray-900" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
        </div>
        <h3 class="font-display font-semibold text-gray-900 text-xl mb-2">Phone</h3>
        <a href={c.phoneClick} class="font-semibold text-lg transition-colors hover:opacity-80" style="color:#F2A93B;">{c.phoneDisplay}</a>
        <p class="text-gray-500 text-sm mt-1">Same-day response on all calls</p>
      </div>

      <div class="bg-white p-8" style="border-top: 2px solid #F2A93B;">
        <div class="w-12 h-12 flex items-center justify-center mb-5" style="background:#F2A93B;">
          <svg class="w-6 h-6 text-gray-900" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
        </div>
        <h3 class="font-display font-semibold text-gray-900 text-xl mb-2">Email</h3>
        <a href={`mailto:${c.email}`} class="transition-colors break-all hover:opacity-80" style="color:#F2A93B;">{c.email}</a>
        <p class="text-gray-500 text-sm mt-1">Response within one business day</p>
      </div>

      <div class="bg-white p-8 sm:col-span-2 lg:col-span-1" style="border-top: 2px solid #F2A93B;">
        <div class="w-12 h-12 flex items-center justify-center mb-5" style="background:#F2A93B;">
          <svg class="w-6 h-6 text-gray-900" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <h3 class="font-display font-semibold text-gray-900 text-xl mb-3">Business Hours</h3>
        <div class="space-y-1.5 text-sm">
          <div class="flex justify-between gap-4">
            <span class="text-gray-500">Mon–Fri</span>
            <span class="text-gray-800 font-medium">7:00 AM – 6:00 PM</span>
          </div>
          <div class="flex justify-between gap-4">
            <span class="text-gray-500">Saturday</span>
            <span class="text-gray-800 font-medium">8:00 AM – 3:00 PM</span>
          </div>
          <div class="flex justify-between gap-4">
            <span class="text-gray-500">Sunday</span>
            <span class="text-gray-800 font-medium">By Appointment</span>
          </div>
        </div>
      </div>

    </div>

    <div class="mt-px bg-gray-50 border border-gray-200 px-8 py-5 flex flex-col sm:flex-row sm:items-center gap-3">
      <svg class="w-5 h-5 flex-shrink-0" style="color:#F2A93B;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
      <span class="text-gray-600 text-sm">{c.address}</span>
      <span class="hidden sm:inline text-gray-300">·</span>
      <span class="text-gray-500 text-sm">{c.serviceArea}</span>
    </div>

  </div>
</section>

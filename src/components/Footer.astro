---
import content from '../data/content.json';
const { businessName, contact, hours, social, services, footer } = content;
const year = new Date().getFullYear();
---

<footer style="background:#F2A93B;">

  <div class="max-w-7xl mx-auto px-6 lg:px-10 pt-10 pb-6 flex flex-col sm:flex-row items-center justify-between gap-4 border-b border-black/10">
    <a href="/" class="flex items-center flex-shrink-0">
      <span style="width:4px; height:36px; background:#0f0f0f; display:inline-block; margin-right:10px; flex-shrink:0;"></span>
      <span class="flex flex-col leading-none">
        <span style="font-size:1.35rem; font-weight:900; letter-spacing:-0.02em; color:#0f0f0f; line-height:1;">{businessName.toUpperCase().split(' ')[0]}</span>
        <span style="font-size:0.6rem; font-weight:600; letter-spacing:0.18em; color:#0f0f0f; opacity:0.6; text-transform:uppercase; line-height:1; margin-top:3px;">Handyman Services</span>
      </span>
    </a>
    <div class="flex gap-3">
      <a href="/contact" style="background:#0f0f0f;" class="text-white font-bold text-sm px-5 py-2.5 hover:bg-gray-800 transition-colors">Get a Free Quote</a>
      <a href={contact.phoneClick} class="border-2 border-black text-black font-bold text-sm px-5 py-2.5 hover:bg-black hover:text-white transition-colors">{contact.phoneDisplay}</a>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-10 py-10 grid grid-cols-2 lg:grid-cols-4 gap-8">

    <!-- Services links — built from content.services -->
    <div>
      <h4 class="text-black text-xs font-bold uppercase tracking-wider mb-4">Services</h4>
      <ul class="space-y-2">
        {services.map((svc) => (
          <li>
            <a href={`/services#${svc.id}`} class="text-black/70 hover:text-black text-sm transition-colors">
              {svc.name}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Quick links — only pages that exist -->
    <div>
      <h4 class="text-black text-xs font-bold uppercase tracking-wider mb-4">Quick Links</h4>
      <ul class="space-y-2">
        <li><a href="/" class="text-black/70 hover:text-black text-sm transition-colors">Home</a></li>
        <li><a href="/services" class="text-black/70 hover:text-black text-sm transition-colors">Services</a></li>
        <li><a href="/about" class="text-black/70 hover:text-black text-sm transition-colors">About Us</a></li>
        <li><a href="/contact" class="text-black/70 hover:text-black text-sm transition-colors">Contact</a></li>
        <li><a href="/contact#quote" class="text-black/70 hover:text-black text-sm transition-colors">Free Quote</a></li>
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h4 class="text-black text-xs font-bold uppercase tracking-wider mb-4">Contact</h4>
      <ul class="space-y-3">
        <li>
          <a href={contact.phoneClick} class="text-black/70 hover:text-black text-sm transition-colors flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            {contact.phoneDisplay}
          </a>
        </li>
        <li>
          <a href={`mailto:${contact.email}`} class="text-black/70 hover:text-black text-sm transition-colors flex items-start gap-2 break-all">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            {contact.email}
          </a>
        </li>
        <li>
          <span class="text-black/70 text-sm flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            {contact.address}
          </span>
        </li>
      </ul>
    </div>

    <!-- Social + Hours -->
    <div>
      <h4 class="text-black text-xs font-bold uppercase tracking-wider mb-4">Follow Us</h4>
      <div class="flex gap-3 mb-5">
        <a href={social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-9 h-9 flex items-center justify-center bg-black/10 hover:bg-black hover:text-white text-black transition-colors">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href={social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-9 h-9 flex items-center justify-center bg-black/10 hover:bg-black hover:text-white text-black transition-colors">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
        </a>
        <a href={social.google} target="_blank" rel="noopener noreferrer" aria-label="Google" class="w-9 h-9 flex items-center justify-center bg-black/10 hover:bg-black hover:text-white text-black transition-colors">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/></svg>
        </a>
        <a href={social.yelp} target="_blank" rel="noopener noreferrer" aria-label="Yelp" class="w-9 h-9 flex items-center justify-center bg-black/10 hover:bg-black hover:text-white text-black transition-colors">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M20.16 12.73l-4.703 1.14c-.435.105-.864-.205-.864-.652 0-.24.116-.46.312-.594l3.9-2.61c.37-.248.868-.118 1.07.278.42.826.477 1.843.285 2.438zm-2.045 3.837l-4.028 2.378c-.372.22-.847.068-1.02-.322-.1-.228-.07-.49.08-.69l2.99-3.96c.283-.375.822-.38 1.104-.002.717.956 1.063 2.028.874 2.596zm-6.107 4.682c0 .454-.376.823-.83.823-.207 0-.404-.076-.557-.213l-3.34-3.02c-.3-.272-.3-.73 0-1.001l3.34-3.022c.304-.275.778-.22 1.012.117.08.116.127.255.127.397l.247 5.92zm-5.67-9.028l-4.027-2.378c-.518-.306-.626-.995-.235-1.438.18-.205.44-.32.713-.31l5.04.19c.457.017.81.4.794.856-.008.194-.086.378-.22.517L6.338 12.22zm-.663-5.637l2.993 3.96c.28.373.18.897-.222 1.142-.24.146-.54.154-.79.02L3.64 8.84c-.395-.21-.536-.704-.32-1.104.44-.831 1.193-1.45 1.8-1.574.213-.044.427.005.58.144z"/></svg>
        </a>
      </div>
      <p class="text-black/60 text-xs leading-relaxed">
        {hours.weekdays}<br/>
        {hours.saturday}<br/>
        {hours.sunday}
      </p>
    </div>

  </div>

  <div class="border-t border-black/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-4 text-center">
      <p class="text-black/60 text-xs">&copy; {year} {footer.copyright}</p>
    </div>
  </div>

</footer>

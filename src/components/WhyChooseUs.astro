---
import content from '../data/content.json';
import Icon from './Icon.astro';
const items = content.whyChooseUs;
---

<section class="py-12 md:py-16" style="background:#0f0f0f;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-0.5" style="background:#F2A93B;"></div>
        <span class="text-xs font-bold uppercase tracking-widest" style="color:#F2A93B;">Why ReliableFix</span>
      </div>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white">
        Why Customers Choose Us
      </h2>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-px" style="background:#2a2a2a;">
      {items.map((item) => (
        <div class="p-5 md:p-8 flex flex-col gap-3 transition-colors" style="background:#1a1a1a;">
          <div class="w-12 h-12 flex items-center justify-center flex-shrink-0" style="background:#F2A93B;">
            <Icon name={item.icon} class="w-6 h-6 text-gray-900" />
          </div>
          <p class="text-white font-semibold leading-snug text-lg">{item.text}</p>
        </div>
      ))}
    </div>

  </div>
</section>

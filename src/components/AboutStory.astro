---
import content from '../data/content.json';
const about = content.about;
---

<section class="py-12 md:py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start">

      <div class="lg:w-5/12">
        <div class="overflow-hidden aspect-[4/3]" style={`background: ${about.storyImage.fallback}`}>
          <img
            src={about.storyImage.url}
            alt={about.storyImage.alt}
            class="w-full h-full object-cover"
            loading="lazy"
            onerror="this.style.display='none'"
          />
        </div>
        <div class="h-1 w-full" style="background:#F2A93B;"></div>
      </div>

      <div class="lg:w-7/12">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-0.5" style="background:#F2A93B;"></div>
          <span class="text-xs font-bold uppercase tracking-widest" style="color:#F2A93B;">Our Story</span>
        </div>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-gray-900 mb-6 leading-tight">
          Built on Reliability.<br/>Licensed for Results.
        </h2>
        <div class="space-y-4">
          {about.originStory.map((para) => (
            <p class="text-gray-600 leading-relaxed text-base">{para}</p>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

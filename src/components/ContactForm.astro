---
import content from '../data/content.json';
const form = content.contactForm;
const formAction = `https://formsubmit.co/${form.contactEmail}`;
---

<section class="py-12 md:py-16 bg-gray-50 border-t border-gray-100">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-0.5" style="background:#F2A93B;"></div>
        <span class="text-xs font-bold uppercase tracking-widest" style="color:#F2A93B;">Get a Quote</span>
      </div>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-gray-900 mb-2">{form.heading}</h2>
      <p class="text-gray-500">{form.subheading}</p>
    </div>

    <div class="bg-white border border-gray-200 p-8 md:p-10">
      <form action={formAction} method="POST" class="space-y-5">
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_subject" value={`New inquiry from ${content.businessName} website`} />
        <input type="hidden" name="_template" value="table" />
        <input type="text" name="_honey" style="display:none" />

        <div>
          <label for="name" class="block text-sm font-semibold text-gray-700 mb-1.5">{form.fields.name}</label>
          <input
            type="text" id="name" name="name" required
            class="w-full px-4 py-3 border border-gray-300 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:border-amber-500 transition-all"
            style="focus:ring-color:#F2A93B;"
            placeholder="John Smith"
          />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">{form.fields.email}</label>
            <input
              type="email" id="email" name="email" required
              class="w-full px-4 py-3 border border-gray-300 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:border-amber-500 transition-all"
              placeholder="john@example.com"
            />
          </div>
          <div>
            <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1.5">{form.fields.phone}</label>
            <input
              type="tel" id="phone" name="phone"
              class="w-full px-4 py-3 border border-gray-300 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:border-amber-500 transition-all"
              placeholder="(585) 555-1234"
            />
          </div>
        </div>

        <div>
          <label for="message" class="block text-sm font-semibold text-gray-700 mb-1.5">{form.fields.message}</label>
          <textarea
            id="message" name="message" rows="5" required
            class="w-full px-4 py-3 border border-gray-300 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:border-amber-500 transition-all resize-vertical"
            placeholder="Describe what needs fixing, your address, and preferred time..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full py-4 font-bold text-base tracking-wide flex items-center justify-center gap-2 text-gray-900 hover:opacity-90 transition-opacity"
          style="background:#F2A93B;"
        >
          {form.submitLabel}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </button>

      </form>
    </div>

  </div>
</section>

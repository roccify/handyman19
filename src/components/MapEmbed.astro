---
import content from '../data/content.json';
const c = content.contact;
---

<section class="bg-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 text-center text-gray-500 text-sm">
    {c.mapCaption}
  </div>
  <div class="w-full h-72 md:h-96">
    <iframe
      src={c.googleMapsEmbed}
      width="100%"
      height="100%"
      style="border:0;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="ReliableFix Handyman Services location map"
    ></iframe>
  </div>
</section>

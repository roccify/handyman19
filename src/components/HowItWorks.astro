---
import content from '../data/content.json';
const { headline, subheadline, steps } = content.howItWorks;
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="mb-12">
      <p class="uppercase text-xs tracking-widest font-semibold text-gray-400 mb-3">THE PROCESS</p>
      <h2 class="text-4xl font-bold text-gray-900 mb-4">{headline}</h2>
      <p class="text-base text-gray-500 max-w-lg">{subheadline}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border border-gray-200">
      {steps.map((step, i) => (
        <div class={`p-8 md:p-10 relative ${i < steps.length - 1 ? 'border-b md:border-b-0 md:border-r border-gray-200' : ''}`}>
          <div class="flex items-center gap-4 mb-5">
            <div class="w-12 h-12 flex items-center justify-center flex-shrink-0" style="background:#F2A93B;">
              <span class="font-bold text-2xl text-black">{step.number}</span>
            </div>
          </div>
          <h3 class="font-bold text-gray-900 text-lg mb-3">{step.title}</h3>
          <p class="text-gray-500 text-base leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

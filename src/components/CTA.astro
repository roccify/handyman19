---
import content from '../data/content.json';
const cta = content.ctaBanner;
---

<section class="relative py-14 md:py-20 overflow-hidden" style="background:#0f0f0f;">
  <div class="absolute inset-0" style={`background: ${cta.image.fallback};`}></div>
  <img
    src={cta.image.url}
    alt={cta.image.alt}
    class="absolute inset-0 w-full h-full object-cover"
    loading="lazy"
    onerror="this.style.display='none'"
  />
  <div class="absolute inset-0" style="background:#0f0f0f; opacity:0.92;"></div>

  <div class="absolute left-0 top-0 bottom-0 w-1" style="background:#F2A93B;"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-6 h-0.5" style="background:#F2A93B;"></div>
        <span class="text-xs font-bold uppercase tracking-widest" style="color:#F2A93B;">Get Started Today</span>
      </div>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4 leading-tight">
        {cta.headline}
      </h2>
      <p class="text-gray-300 text-lg mb-8 max-w-2xl">
        {cta.subheadline}
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href={cta.ctaPrimary.href} class="inline-flex items-center justify-center px-8 py-4 font-bold text-base tracking-wide text-gray-900 hover:opacity-90 transition-opacity" style="background:#F2A93B;">
          {cta.ctaPrimary.label}
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
        <a href={cta.ctaSecondary.href} class="inline-flex items-center justify-center px-8 py-4 border border-gray-600 text-gray-200 hover:border-gray-400 hover:text-white font-semibold text-base transition-colors">
          {cta.ctaSecondary.label}
        </a>
      </div>
    </div>
  </div>
</section>

---
import content from '../data/content.json';
const gallery = content.gallery ?? [];
---

{gallery.length > 0 && (
  <section class="py-16" style="background:#f5f5f5;">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="mb-10">
        <p class="uppercase text-xs tracking-widest font-semibold text-gray-400 mb-3">PORTFOLIO</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-3">Our Work</h2>
        <p class="text-gray-500 max-w-xl text-base">Recent projects completed across Rochester and Monroe County.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-5">
        {gallery.map((item) => (
          <div class="group overflow-hidden bg-white border border-gray-100 flex flex-col">
            <div class="relative overflow-hidden" style="padding-bottom: 70%;">
              <img
                src={item.url}
                alt={item.alt}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                onerror="this.style.display='none'"
              />
            </div>
            {(item.title || item.location) && (
              <div class="px-4 py-3 bg-white border-t border-gray-100">
                {item.title && <div class="font-semibold text-gray-800 text-sm leading-snug">{item.title}</div>}
                {item.location && (
                  <div class="text-gray-400 text-xs flex items-center gap-1 mt-1">
                    <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                    </svg>
                    {item.location}
                  </div>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
)}

---
import content from '../data/content.json';
import Icon from './Icon.astro';

const displayIds = content.homepageServiceIds;
const services = content.services.filter(s => displayIds.includes(s.id));
---

<section class="py-12 md:py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="mb-12" style="display:none;">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-0.5" style="background:#F2A93B;"></div>
        <span class="text-xs font-bold uppercase tracking-widest" style="color:#F2A93B;">What We Do</span>
      </div>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-gray-900 mb-3">
        Our Handyman Services
      </h2>
      <p class="text-gray-500 max-w-xl">
        Licensed solutions for every home repair need — residential and multi-trade across Rochester and Monroe County.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <div class="group bg-white shadow-sm hover:shadow-md transition-shadow duration-300 flex flex-col">
          <div class="relative overflow-hidden" style={`background: ${service.image.fallback}; height: 220px;`}>
            <img
              src={service.image.url}
              alt={service.image.alt}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              onerror="this.style.display='none'"
            />
          </div>

          <div class="p-6 flex flex-col flex-1 items-center text-center">
            <h3 class="font-display font-bold text-gray-900 text-xl mb-3">
              {service.name}
            </h3>
            <p class="text-gray-500 text-base leading-relaxed flex-1 mb-6">
              {service.shortDescription}
            </p>
            <a
              href={`/services#${service.id}`}
              class="inline-block font-bold text-sm px-8 py-3 text-black transition-all hover:brightness-95"
              style="background:#F2A93B; border-radius: 999px;"
            >
              Read More
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-8 text-center">
      <a href="/services" class="inline-flex items-center gap-2 font-semibold transition-colors" style="color:#F2A93B;">
        View All Services & Details
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>
    </div>

  </div>
</section>

---
import Icon from './Icon.astro';

interface Props {
  service: {
    id: string;
    name: string;
    icon: string;
    image: { url: string; alt: string; fallback: string };
    problem: string[];
    solution: string[];
    benefits: string[];
  };
  index: number;
}

const { service, index } = Astro.props;
const isEven = index % 2 === 0;
---

<section id={service.id} class={`py-16 md:py-20 ${isEven ? 'bg-white' : 'bg-gray-50'} scroll-mt-20 border-t border-gray-100`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class={`flex flex-col ${isEven ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-8 lg:gap-14 mb-12`}>
      <div class="lg:w-5/12">
        <div class="overflow-hidden aspect-[4/3]" style={`background: ${service.image.fallback}`}>
          <img
            src={service.image.url}
            alt={service.image.alt}
            class="w-full h-full object-cover"
            loading="lazy"
            onerror="this.style.display='none'"
          />
        </div>
      </div>

      <div class="lg:w-7/12">
        <div class="flex items-center gap-4 mb-5">
          <div class="w-12 h-12 flex items-center justify-center flex-shrink-0" style="background:#F2A93B;">
            <Icon name={service.icon} class="w-6 h-6 text-gray-900" />
          </div>
          <div>
            <div class="text-xs font-bold uppercase tracking-widest mb-0.5" style="color:#F2A93B;">Service</div>
            <h2 class="font-display text-2xl md:text-3xl lg:text-4xl font-bold text-gray-900 leading-tight">{service.name}</h2>
          </div>
        </div>

        <div class="space-y-4 border-l-2 border-gray-200 pl-5">
          {service.problem.map((p) => (
            <p class="text-gray-600 leading-relaxed text-base">{p}</p>
          ))}
        </div>
      </div>
    </div>

    <div class="max-w-4xl mb-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-6 h-0.5" style="background:#F2A93B;"></div>
        <h3 class="font-display text-xl md:text-2xl font-semibold text-gray-900">How We Solve It</h3>
      </div>
      <div class="space-y-4">
        {service.solution.map((s) => (
          <p class="text-gray-600 leading-relaxed text-base">{s}</p>
        ))}
      </div>
    </div>

    <div class="max-w-4xl mb-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-6 h-0.5" style="background:#F2A93B;"></div>
        <h3 class="font-display text-xl md:text-2xl font-semibold text-gray-900">Key Benefits</h3>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {service.benefits.map((b) => (
          <div class="flex items-start gap-3 border border-gray-200 p-4 hover:border-amber-300 transition-colors">
            <div class="w-5 h-5 flex items-center justify-center flex-shrink-0 mt-0.5" style="background:#F2A93B;">
              <svg class="w-3 h-3 text-gray-900" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            </div>
            <span class="text-gray-800 font-medium text-sm">{b}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="max-w-4xl">
      <a href="/contact" class="inline-flex items-center px-8 py-4 font-bold text-base tracking-wide text-gray-900" style="background:#F2A93B;">
        Get a Free Quote
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>
    </div>

  </div>
</section>

---
import content from '../data/content.json';
const faqs = content.faq;
const left = faqs.filter((_, i) => i % 2 === 0);
const right = faqs.filter((_, i) => i % 2 === 1);
---

<section class="py-12 md:py-16 bg-white border-t border-gray-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-0.5" style="background:#F2A93B;"></div>
        <span class="text-xs font-bold uppercase tracking-widest" style="color:#F2A93B;">FAQ</span>
      </div>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-gray-900">
        Common Questions
      </h2>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
      <!-- LEFT COLUMN -->
      <div style="display:flex; flex-direction:column; gap:8px;">
        {left.map((faq, i) => (
          <div class="faq-left" data-col="left" data-idx={i}
            style="border:2px solid #F2A93B; padding:14px 18px; cursor:pointer;">
            <div style="display:flex; align-items:center; gap:12px;">
              <span class="faq-icon" style="color:#F2A93B; font-weight:700; font-size:1.1rem; flex-shrink:0; width:16px; text-align:center;">+</span>
              <h3 style="font-weight:700; color:#111; font-size:0.95rem; line-height:1.4; margin:0;">{faq.question}</h3>
            </div>
            <p class="faq-answer" style="display:none; margin:12px 0 0 28px; color:#555; font-size:0.93rem; line-height:1.75;">{faq.answer}</p>
          </div>
        ))}
      </div>
      <!-- RIGHT COLUMN -->
      <div style="display:flex; flex-direction:column; gap:8px;">
        {right.map((faq, i) => (
          <div class="faq-right" data-col="right" data-idx={i}
            style="border:2px solid #F2A93B; padding:14px 18px; cursor:pointer;">
            <div style="display:flex; align-items:center; gap:12px;">
              <span class="faq-icon" style="color:#F2A93B; font-weight:700; font-size:1.1rem; flex-shrink:0; width:16px; text-align:center;">+</span>
              <h3 style="font-weight:700; color:#111; font-size:0.95rem; line-height:1.4; margin:0;">{faq.question}</h3>
            </div>
            <p class="faq-answer" style="display:none; margin:12px 0 0 28px; color:#555; font-size:0.93rem; line-height:1.75;">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>

    <script>
      function initCol(selector) {
        const items = document.querySelectorAll(selector);
        items.forEach(item => {
          item.addEventListener('click', () => {
            const answer = item.querySelector('.faq-answer');
            const icon = item.querySelector('.faq-icon');
            const isOpen = answer.style.display !== 'none';
            // close all in this column
            items.forEach(el => {
              el.querySelector('.faq-answer').style.display = 'none';
              el.querySelector('.faq-icon').textContent = '+';
            });
            // open if was closed
            if (!isOpen) {
              answer.style.display = 'block';
              icon.textContent = '–';
            }
          });
        });
      }
      initCol('.faq-left');
      initCol('.faq-right');
    </script>

  </div>
</section>

---
import content from '../data/content.json';
const { testimonials } = content;
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="text-center mb-14">
      <p class="uppercase text-xs tracking-widest text-gray-400 font-semibold mb-3">WHAT CLIENTS SAY</p>
      <h2 class="text-4xl font-bold text-gray-900">Real Reviews from Rochester Homeowners</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <div class="bg-white p-8 shadow-md" style="border-top: 3px solid #F2A93B;">
          <div class="flex gap-1 mb-4">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-4 h-4" style="fill:#F2A93B;" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-base leading-relaxed text-gray-600 italic mb-6">"{t.quote}"</p>
          <div class="border-t border-gray-100 pt-4">
            <p class="font-bold text-gray-900">{t.name}</p>
            <p class="text-sm text-gray-400 mt-0.5">{t.location}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

---
import content from '../data/content.json';
import Icon from './Icon.astro';
const credentials = content.about.credentials;
---

<section class="py-12 md:py-16" style="background:#0f0f0f;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-0.5" style="background:#F2A93B;"></div>
        <span class="text-xs font-bold uppercase tracking-widest" style="color:#F2A93B;">Credentials</span>
      </div>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white">Licenses & Certifications</h2>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-px" style="background:#2a2a2a;">
      {credentials.map((cred) => (
        <div class="p-6 flex items-center gap-4 transition-colors" style="background:#1a1a1a;">
          <div class="w-10 h-10 flex items-center justify-center flex-shrink-0" style="background:#F2A93B;">
            <Icon name={cred.icon} class="w-5 h-5 text-gray-900" />
          </div>
          <span class="text-white font-medium text-sm">{cred.text}</span>
        </div>
      ))}
    </div>

  </div>
</section>

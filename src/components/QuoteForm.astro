---
import content from '../data/content.json';
const { contact, testimonials, contactForm } = content;
const featured = (testimonials ?? [])[0] ?? { quote: '', name: '', location: '', rating: 5 };
const email = contactForm?.contactEmail ?? contact.email;
---

<section class="py-20" style="background:#f5f5f5;">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="text-center mb-12">
      <p class="uppercase text-xs tracking-widest text-gray-500 font-semibold mb-3">GET A QUOTE</p>
      <h2 class="text-4xl font-bold text-gray-900">{contactForm?.heading ?? 'Receive Your Free Quote'}</h2>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

      <div class="bg-white p-8 shadow-md">
        <form action={`https://formsubmit.co/${email}`} method="POST" class="space-y-5">
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_subject" value="New quote request from website" />
          <input type="text" name="_honey" style="display:none" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">{contactForm?.fields?.name ?? 'Full Name'}</label>
              <input type="text" name="name" required placeholder="John Smith" class="w-full border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:border-yellow-400 transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">{contactForm?.fields?.phone ?? 'Phone Number'}</label>
              <input type="tel" name="phone" placeholder="(585) 555-1234" class="w-full border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:border-yellow-400 transition-colors" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">{contactForm?.fields?.email ?? 'Email Address'}</label>
            <input type="email" name="email" required placeholder="john@example.com" class="w-full border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:border-yellow-400 transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">{contactForm?.fields?.message ?? 'Message'}</label>
            <textarea name="message" rows="5" required placeholder="Describe what needs fixing..." class="w-full border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:border-yellow-400 transition-colors resize-vertical"></textarea>
          </div>
          <button type="submit" style="background:#F2A93B;" class="w-full text-black font-bold text-sm py-4 hover:brightness-95 transition-all">
            {contactForm?.submitLabel ?? 'Send Request'}
          </button>
        </form>
      </div>

      <div class="flex flex-col gap-6">
        <div class="bg-white p-8 shadow-md" style="border-left: 4px solid #F2A93B;">
          <div class="flex gap-1 mb-4">
            {Array.from({ length: featured.rating }).map(() => (
              <svg class="w-5 h-5" style="fill:#F2A93B;" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-base leading-relaxed text-gray-600 italic mb-6">"{featured.quote}"</p>
          <div class="border-t border-gray-100 pt-4">
            <p class="font-bold text-gray-900">{featured.name}</p>
            <p class="text-sm text-gray-400 mt-0.5">{featured.location}</p>
          </div>
        </div>
        <div class="bg-white p-8 shadow-md">
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Get in Touch</h3>
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 flex items-center justify-center flex-shrink-0" style="background:#F2A93B;">
                <svg class="w-4 h-4" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
              </div>
              <a href={contact.phoneClick} class="text-gray-700 font-semibold hover:text-yellow-600 transition-colors">{contact.phoneDisplay}</a>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 flex items-center justify-center flex-shrink-0" style="background:#F2A93B;">
                <svg class="w-4 h-4" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
              </div>
              <a href={`mailto:${contact.email}`} class="text-gray-700 hover:text-yellow-600 transition-colors">{contact.email}</a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

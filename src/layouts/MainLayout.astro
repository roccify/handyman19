---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import content from '../data/content.json';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = content.seo.home.description, ogImage = content.seo.home.ogImage } = Astro.props;
const firstLetter = content.shortName.charAt(0);
const siteUrl = Astro.url.origin;
const currentUrl = Astro.url.href;
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={currentUrl} />
  {ogImage && <meta property="og:image" content={`${siteUrl}${ogImage}`} />}
  <link rel="icon" type="image/svg+xml" href={`data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%23F2A93B'/><text x='50' y='72' font-size='60' font-family='Georgia,serif' font-weight='700' fill='%230f0f0f' text-anchor='middle'>${firstLetter}</text></svg>`} />
  <link rel="apple-touch-icon" href={`data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 180 180'><rect width='180' height='180' fill='%23F2A93B'/><text x='90' y='125' font-size='100' font-family='Georgia,serif' font-weight='700' fill='%230f0f0f' text-anchor='middle'>${firstLetter}</text></svg>`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style is:global>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', system-ui, sans-serif; color: #1a1a1a; background: #fff; }
    html { scroll-behavior: smooth; }
  </style>
</head>
<body>
  <Header />
  <main><slot /></main>
  <Footer />
  <div id="mobile-cta" class="fixed bottom-0 left-0 right-0 z-50 md:hidden hidden" style="background:#F2A93B;">
    <a href={content.contact.phoneClick} class="flex items-center justify-center gap-2 font-bold text-base text-black py-4">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
      Call {content.contact.phoneDisplay}
    </a>
  </div>
  <script is:inline>
    (function(){var el=document.getElementById('mobile-cta');if(!el)return;window.addEventListener('scroll',function(){if(window.scrollY>300)el.classList.remove('hidden');},{passive:true});})();
  </script>
</body>
</html>
